# CereMind configuration. Copy to .env and fill in.

# --- Cerebras (Gemma 4 31B) ---
# If unset, CereMind runs with a built-in deterministic "simulated agent" so the
# full UX is demoable offline. Set this to use real ultra-fast Cerebras inference.
CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_MODEL=gemma-4-31b

# --- GPU baseline (for the side-by-side speed comparison) ---
# Any OpenAI-compatible endpoint. If unset, the baseline pane is simulated at a
# representative GPU token rate so the comparison still renders.
BASELINE_BASE_URL=
BASELINE_API_KEY=
BASELINE_MODEL=
BASELINE_LABEL=GPU baseline (representative)
# Tokens/sec used when the baseline is simulated.
BASELINE_SIM_TPS=55

# --- Embeddings ---
# auto = use EmbeddingGemma if installed, else a generic ST model, else a
# lightweight hashing vectorizer. Force with: embeddinggemma | hashing
EMBEDDING_BACKEND=auto
EMBEDDING_GEMMA_MODEL=google/embeddinggemma-300m
HUGGINGFACE_TOKEN=

# --- Pipeline backend the agent investigates ---
# mock = seeded deterministic environment (default). airflow = local Airflow REST.
PIPELINE_BACKEND=mock
AIRFLOW_BASE_URL=http://localhost:8080/api/v1
AIRFLOW_USERNAME=airflow
AIRFLOW_PASSWORD=airflow

# --- Misc ---
# Default reasoning_effort knob composed with tool calls (low|medium|high).
DEFAULT_REASONING_EFFORT=medium
